OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Teamsale CRM (Zadarma) integration.
# Example: https://api.zadarma.com/v1/zcrm/leads
TEAMSALE_WEBHOOK_URL=
ZADARMA_KEY=
ZADARMA_SECRET=
TEAMSALE_SOURCE_ID=form
TEAMSALE_EXTRA_FIELDS=

# Optional AI manager estimate range. Leave empty if you do not want approximate prices.
PANEL_PRICE_MIN_MDL_M2=
PANEL_PRICE_MAX_MDL_M2=

# Optional store branches / pickup points. If empty, the Balti branch from server.js is used.
# STORE_BRANCHES_JSON=[{"id":"balti-dovator","name":"TEHNOFASAD Balti","type":"warehouse_store","city":"Balti","address":"mun. Balti, str. Lev Dovator 1","phone":"+373 791 55 791","email":"info@tehnofasad.md","hours":{"weekdays":"08:00-17:00","saturday":"09:00-14:00","sunday":"closed"},"geo":{"latitude":47.7741648,"longitude":27.9116626},"services":["pickup","stock_check","consultation","reservation"],"isMain":true,"active":true}]
